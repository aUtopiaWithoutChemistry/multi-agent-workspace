{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["open", "claimed", "in_progress", "review", "done"]
    },
    "type": {
      "type": "string",
      "enum": ["spec", "code", "review", "test", "debug", "docs", "refactor", "research"]
    },
    "priority": {
      "type": "number",
      "default": 0
    },
    "claimed_by": {
      "type": ["string", "null"]
    },
    "claimed_at": {
      "type": ["string", "null"]
    },
    "created_by": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "parent_task_id": {
      "type": ["string", "null"]
    },
    "reject_count": {
      "type": "number",
      "default": 0
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "author": { "type": "string" },
          "content": { "type": "string" },
          "timestamp": { "type": "string" }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "progress": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "default": 0
    }
  },
  "required": ["id", "title", "status", "type", "created_by", "created_at"]
}
